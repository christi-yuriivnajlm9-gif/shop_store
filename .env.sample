# Скопіюй цей файл у .env і заповни своїми значеннями.
# Локально без жодного з цих значень проєкт теж запрацює (SQLite, DEBUG=True).

SECRET_KEY=django-insecure-put-your-own-random-string-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# DATABASE_URL=postgres://user:password@host:5432/dbname

# Безкоштовний акаунт на cloudinary.com — щоб фото товарів не зникали
# після кожного деплою на Render (там диск ефемерний).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
